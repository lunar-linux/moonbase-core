          MODULE=ccache
         VERSION=0.14.0
          SOURCE=sccache-v$VERSION-aarch64-pc-windows-msvc.tar.gz
      SOURCE_URL=https://github.com/mozilla/sccache/releases/download/v$VERSION/
      SOURCE_VFY=sha256:b416e81f946c607467c5383022842649569d73f468a8e42b4536998e3d784224
        WEB_SITE=https://github.com/mozilla/sccache
         ENTERED=20020701
         UPDATED=20260312
           SHORT="Distributed compiler cache written in Rust"

cat << EOF
sccache is a ccache-like compiler caching tool. It is used as a compiler
wrapper and avoids compilation when possible, storing cached results either
locally or in a remote storage backend. sccache is written in Rust and supports
compilation caching for C/C++ code and can significantly speed up rebuilds.
EOF
