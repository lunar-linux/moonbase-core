          MODULE=lunar
         VERSION=52
          SOURCE=$MODULE-$VERSION.tar.gz
         SOURCE2=llint-v$VERSION-linux-amd64.tar.xz
         SOURCE3=llint-v$VERSION-linux-i686.tar.xz
SOURCE_DIRECTORY=$BUILD_DIRECTORY/$MODULE-$VERSION
 SOURCE_URL_FULL=https://github.com/lunar-linux/lunar/archive/refs/tags/v$VERSION.tar.gz
     SOURCE2_URL=https://github.com/lunar-linux/lunar/releases/download/v$VERSION
     SOURCE3_URL=https://github.com/lunar-linux/lunar/releases/download/v$VERSION
      SOURCE_VFY=sha256:4d3e8519754889ef6a52d4a6f2624f7557c2c2e9ae527e9907de6485e00b1952
     SOURCE2_VFY=sha256:0c27852827ca41080f89e3db97f820ce56412dbe904043e260c1e5c75a8d94f6
     SOURCE3_VFY=sha256:f2cf2443fd50ac595102a97479c371455f0930d562511b43f180dc2ab860e889
        WEB_SITE=http://lunar-linux.org/
         ENTERED=20020218
         UPDATED=20260307
           SHORT="lunar contains the package management tools for Lunar-Linux."
USE_WRAPPERS=off

cat << EOF
lunar - Tools package management by source.

lunar includes the following files:
/etc/lunar/config /etc/lunar/dialogrc /etc/lunar/local /etc/lunar/mirrors configuration files.
/usr/share/doc/lunar/COPYING-2.0 /usr/share/doc/lunar/CVS /usr/share/doc/lunar/ChangeLog /usr/share/doc/lunar/Changelog /usr/share/doc/lunar/README /usr/share/doc/lunar/contributions /usr/share/doc/lunar/gpl.html documentation, please read
/usr/sbin/lunar menu driven interface
/usr/sbin/lget downloads modules sources
/usr/sbin/lin installs modules
/usr/sbin/lrm removes modules
/usr/sbin/lvu provides information about the box
/var/lib/lunar/excluded list of files that are ignored
/var/lib/lunar/protected list of files that will not be deleted
/var/lib/lunar/subroutines common subroutines

and man pages.

EOF
