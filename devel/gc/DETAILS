          MODULE=gc
         VERSION=8.2.12
          SOURCE=$MODULE-$VERSION.tar.gz
      SOURCE_URL=https://github.com/ivmai/bdwgc/releases/download/v$VERSION/
      SOURCE_VFY=sha256:42e5194ad06ab6ffb806c83eb99c03462b495d979cda782f3c72c08af833cd4e
        WEB_SITE=http://www.hboehm.info/gc/
         ENTERED=20020314
         UPDATED=20260312
           SHORT="A garbage collector"

cat << EOF
The Boehm-Demers-Weiser conservative garbage collector can be used as a garbage
collecting replacement for C malloc or C++ new. It is also used by a number of
programming language implementations that use C as intermediate code.
Alternatively, it may be used as a leak detector for C or C++ programs
A slightly older version of the garbage collector is also included as part of
the GNU compiler (gcc) distribution.
EOF
